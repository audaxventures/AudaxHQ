# Shared passcode that gates the whole app (see src/proxy.ts + src/lib/auth.ts).
# Pick something reasonably long — it's the only thing standing between the
# public internet and your client data.
APP_PASSCODE=change-me

# Optional: a separate secret used to sign the session cookie. If omitted,
# APP_PASSCODE is reused as the secret. Set this if you want the ability to
# rotate the passcode without invalidating the signing key relationship, or
# just for extra entropy. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Postgres connection string from your Neon project (Vercel Postgres is
# Neon under the hood). Use the pooled connection string — the app talks to
# Postgres over HTTP via @neondatabase/serverless, not a raw TCP pool, so a
# single connection string is all that's needed (no separate DIRECT_URL).
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# Supabase project URL and service_role secret key, used for client document
# uploads and the business logo (Storage). Create a private bucket named
# `client-documents` and a PUBLIC bucket named `business-assets` in that
# project — see README.md "Document storage setup" for the full steps. The
# service_role key has full admin access to your Supabase project, so keep
# it out of client-side code and source control; it's only ever read
# server-side (src/lib/storage.ts).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key, used to send "forgot passcode" reset emails (src/lib/email.ts).
# Sign up free at resend.com and create an API key under API Keys.
# Without this set, the "Forgot passcode?" link on the login page will fail
# to send (everything else in the app works fine without it).
RESEND_API_KEY=

# Optional: the "From" address for reset emails. Defaults to Resend's shared
# onboarding@resend.dev sender, which works immediately but looks less
# trustworthy and has lower deliverability — verify your own domain in
# Resend and use an address on it here once you're ready (e.g.
# "Audax HQ <noreply@yourdomain.com>").
RESEND_FROM_EMAIL=
